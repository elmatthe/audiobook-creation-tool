# ─────────────────────────────────────────────────────────────────────────
#  Audiobook Creation Tool — .gitignore
#  Auto-generated / machine-specific artifacts that must never be committed.
# ─────────────────────────────────────────────────────────────────────────

# Virtual environment (repo root; rebuilt fresh by Setup_and_Run on each machine)
.venv/
.python_runtime/

# Python bytecode / caches
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# Build / packaging artifacts
dist/
build/
*.spec
*.egg-info/

# Portable binaries (ffmpeg, etc.) — downloaded by the bootstrap
files/bin/

# Runtime-writable state: logs, settings.json, and the HuggingFace model
# cache (~300 MB Kokoro weights, kept in-tree but never committed).
# Delete files/runtime-data/ + files/bin/ + .venv/ for a full "uninstall".
files/runtime-data/

# Test logs / harness outputs (any folder named test-logs, at any depth)
test-logs/

# Per-voice manual-listen QA samples (generated by tts/generate_voice_samples.py)
files/test-for-manual-listen-elmatthe/

# ─────────────────────────────────────────────────────────────────────
# files/test-files/  — entirely untracked.
# LOCAL testing fixtures only (PDFs, MP3s, M4Bs, EPUBs — may include
# copyrighted media); nothing under it is ever staged or committed.
# To use a fixture in code, point at it via an env var (e.g.
# KOKORO_TEST_PDF_FOLDER) or an absolute path — never rely on git.
# ─────────────────────────────────────────────────────────────────────
files/test-files/
test-files/

# Per-machine Claude Code settings (machine paths/permissions); rest of .claude/ is tracked.
.claude/settings.local.json

# OS cruft
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.vscode/
.idea/
*.swp
