# ─────────────────────────────────────────────────────────────────────────
#  Audiobook Creation Tool — .gitignore
#  Auto-generated / machine-specific artifacts that must never be committed.
# ─────────────────────────────────────────────────────────────────────────

# Virtual environments (rebuilt fresh by setup_and_run on each machine)
.venv/
Windows/.venv/
MacOS/.venv/
.python_runtime/

# Python bytecode / caches
__pycache__/
*.pyc
*.pyo
*.pyd

# Build / packaging artifacts
dist/
build/
*.spec
*.egg-info/

# Bundled portable binaries (ffmpeg, etc.) — downloaded by the bootstrap
Windows/resources/bin/
MacOS/resources/bin/

# Per-session logs and persisted settings (runtime state, not source)
Windows/resources/logs/
MacOS/resources/logs/
Windows/resources/settings.json
MacOS/resources/settings.json

# HuggingFace model cache (~300 MB Kokoro weights) — kept in-tree, never committed
Windows/resources/models/
MacOS/resources/models/

# Voice-verification harness outputs (generated MP3s — runtime, not source)
Windows/resources/test-logs/
MacOS/resources/test-logs/

# Working test folder (per project test-log convention — never shipped)
test-logs/
Windows/test-logs/
MacOS/test-logs/

# ─────────────────────────────────────────────────────────────────────
# test-files/  — entirely untracked.
# The folder is for LOCAL testing only and never enters the repo.
# Drop any input/output fixtures you need (PDFs, MP3s, M4Bs, EPUBs)
# under here freely; nothing in this directory will be staged or
# committed. To use a fixture in code, point at it via an env var or
# ask the user for an absolute path — do not rely on it being in git.
# ─────────────────────────────────────────────────────────────────────
test-files/

# Per-machine Claude Code settings (machine paths/permissions); rest of .claude/ is tracked.
.claude/settings.local.json

# OS cruft
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.vscode/
.idea/
*.swp
